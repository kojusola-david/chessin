// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

enum TimeClass {
  BULLET
  BLITZ
  RAPID
}

enum Termination {
  CHECKMATE
  TIMEOUT
  RESIGNATION
  ABANDONMENT
  AGREEMENT
  INSUFFICIENT_MATERIAL
  FIFTY_MOVE_RULE
  REPETITION
  STALEMATE
}

enum Result {
  BLACK_WIN
  WHITE_WIN
  DRAW
}

model Player {
  id                  String          @id @default(uuid(7)) @db.Uuid
  username            String          @unique
  name                String?
  email               String          @unique
  currentRapidRating  Int
  currentBlitzrating  Int
  currentBulletRating Int
  createdAt           DateTime        @default(now())
  gamesAsWhite        Game[]          @relation("WhiteGames")
  gamesAsBlack        Game[]          @relation("BlackGames")
  ratingHistory       RatingHistory[]
}

model Game {
  id            String          @id @default(uuid(7)) @db.Uuid
  roomId        String
  rated         Boolean
  timeControl   String
  timeClass     TimeClass
  fen           String
  pgn           String
  white         Player          @relation("WhiteGames", fields: [whiteId], references: [id])
  whiteId       String          @db.Uuid
  black         Player          @relation("BlackGames", fields: [blackId], references: [id])
  blackId       String          @db.Uuid
  result        Result?
  termination   Termination?
  ratingChanges RatingHistory[]
}

model RatingHistory {
  id        String   @id @default(uuid(7)) @db.Uuid
  rating    Int
  timeStamp DateTime @default(now())

  player   Player @relation(fields: [playerId], references: [id])
  playerId String @db.Uuid

  game   Game?   @relation(fields: [gameId], references: [id])
  gameId String? @db.Uuid
}
